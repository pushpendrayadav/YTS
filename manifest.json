{
  "manifest_version": 3,
  "name": "YT Summarizer – AI Notes",
  "version": "1.0.0",
  "description": "Generate structured summary.md from any YouTube video — Groq (free), Ollama (private), Claude, or OpenAI.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://api.groq.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "http://localhost:11434/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
